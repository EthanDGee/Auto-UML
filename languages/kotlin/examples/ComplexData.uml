classDiagram
    class ComplexData {
        -raw_bytes: ByteArray
        -items: List~String~
        -config: Map~String, Int~
        -owner: User
        +process(mode:String) void
        +create() ComplexData
    }
    class Metadata {
        +key: String
        +value: String
        +log() void
    }
    ComplexData ..> ComplexData
