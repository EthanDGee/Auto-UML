classDiagram
    class ComplexData {
        -raw_bytes: byte[]
        -items: List~String~
        -config: Map~String, Integer~
        -owner: User
        +process(mode: String) void
        +create() ComplexData
    }
    class Metadata {
        +key: String
        +value: String
        +log() void
    }
    ComplexData --> User
